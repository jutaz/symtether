{
  "name": "symtether",
  "version": "1.0.0",
  "description": "Broken URLs 404. Broken code references don't. #sym: verifies markdown references against the code itself, and fails CI when they break.",
  "keywords": [
    "markdown",
    "linter",
    "documentation",
    "agents",
    "agents-md",
    "tree-sitter",
    "ci",
    "link-checker"
  ],
  "homepage": "https://symtether.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jutaz/symtether.git"
  },
  "bugs": "https://github.com/jutaz/symtether/issues",
  "license": "MIT",
  "author": "Justas Brazauskas",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "symtether": "./dist/cli.js"
  },
  "files": [
    "assets",
    "dist",
    "grammars",
    "schemas",
    "SPEC.md",
    "!dist/**/*.test.js",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc && node scripts/bundle-cli.mjs",
    "build:site": "npm run build && vitepress build docs",
    "dev:site": "npm run build && vitepress dev docs",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "test:coverage": "npm run build && vitest run --coverage",
    "lint": "eslint src/ && prettier --check .",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "vendor:swift": "node scripts/vendor-swift.mjs",
    "favicons:build": "node scripts/render-favicons.mjs",
    "prepublishOnly": "npm run build && npm run lint && vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "tree-sitter": "^0.25.0"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "globby": "^16.2.0",
    "picocolors": "^1.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "web-tree-sitter": "^0.26.10"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@nolebase/vitepress-plugin-og-image": "^2.18.2",
    "@tree-sitter-grammars/tree-sitter-kotlin": "^1.1.0",
    "@tree-sitter-grammars/tree-sitter-lua": "^0.4.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.2.0",
    "@vitest/coverage-v8": "^3.2.6",
    "ajv": "^8.17.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "publint": "^0.3.21",
    "tree-sitter-bash": "^0.25.1",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "^0.23.5",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-elixir": "^0.3.5",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-scala": "^0.24.0",
    "tree-sitter-swift": "^0.7.1",
    "tree-sitter-typescript": "^0.23.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitepress": "^2.0.0-alpha.17",
    "vitepress-plugin-llms": "^1.13.2",
    "vitest": "^3.2.6",
    "wrangler": "^4.107.0"
  }
}
