{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://symtether.dev/schemas/check-output.schema.json",
  "title": "symtether check --json output",
  "description": "Stable contract (v1). Agents and CI parse this. Additive changes only within a version.",
  "type": "object",
  "required": ["version", "summary", "results"],
  "properties": {
    "version": { "const": 1 },
    "summary": {
      "type": "object",
      "required": ["refs", "ast", "lexical", "fileOnly", "broken", "stale"],
      "properties": {
        "refs": { "type": "integer", "minimum": 0 },
        "ast": { "type": "integer", "minimum": 0 },
        "lexical": { "type": "integer", "minimum": 0 },
        "fileOnly": { "type": "integer", "minimum": 0 },
        "broken": { "type": "integer", "minimum": 0 },
        "stale": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "doc",
          "line",
          "target",
          "fragment",
          "status",
          "tier",
          "compat",
          "candidates"
        ],
        "properties": {
          "doc": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "target": { "type": "string" },
          "fragment": { "type": "string" },
          "status": { "enum": ["ok", "broken", "stale", "warning"] },
          "tier": { "enum": ["ast", "lexical", "file-only"] },
          "compat": { "type": "boolean" },
          "message": { "type": "string" },
          "candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["symbol", "kind", "confidence"],
              "properties": {
                "symbol": { "type": "string" },
                "kind": { "type": "string" },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
              },
              "additionalProperties": false
            }
          },
          "fix": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
